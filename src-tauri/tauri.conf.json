{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NexTwist",
  "version": "1.0.0",
  "identifier": "com.nextwist.app",
  "build": {
    "frontendDist": "../frontend/build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": { "script": "npm run dev", "cwd": "../frontend" },
    "beforeBuildCommand": { "script": "npm run build", "cwd": "../frontend" }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "NexTwist",
        "width": 960,
        "height": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["nxm"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.png"],
    "category": "Utility",
    "shortDescription": "Safe, reversible Linux mod manager",
    "longDescription": "NexTwist installs and uninstalls mods safely on Linux: non-destructive, fully reversible, conflict-aware deployment for Proton/Wine games."
  }
}
