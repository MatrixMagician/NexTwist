# Rust build output
/target
**/target

# Node / frontend (Plan 06)
**/node_modules
frontend/.svelte-kit
frontend/build

# Tauri build dirs (Plan 06)
src-tauri/target
src-tauri/gen

# SQLite databases / journals (runtime data, never committed)
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# proptest failure seeds: regenerated on demand during RED runs; not committed so a
# stale seed from a since-fixed generator never re-runs an impossible case.
**/*.proptest-regressions

# Editor / OS noise
.DS_Store
*.swp

# NOTE: Cargo.lock is intentionally NOT ignored.
# NexTwist ships an application/binary (AppImage), so the lockfile is committed
# for reproducible builds.
